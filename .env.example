# KubeShipper environment variables

# --- Server ---
PORT=3000

# --- Auth ---
# Set this to enable token-based authentication on all /services routes.
# Leave unset (or empty) to run in open/dev mode.
# Clients must send:  Authorization: Bearer <your-token>
AUTH_TOKEN=

# --- Kubernetes ---
# Comma-separated list of namespaces kubeshipper is allowed to deploy workloads into.
# REQUIRED — the server will refuse to start if this is missing or empty.
# Each namespace must have a corresponding Role + RoleBinding (or ClusterRole) granted
# to the kubeshipper ServiceAccount.
# Example: MANAGED_NAMESPACES=default,production,staging
MANAGED_NAMESPACES=default

# Path to the SQLite database file.
# In Kubernetes, point this at a PersistentVolumeClaim mount path.
# Example: DB_PATH=/data/kubeshipper.sqlite
# Default: kubeshipper.sqlite (in the current working directory)
DB_PATH=

# KubeShipper environment variables

# --- Server ---
PORT=3000

# --- Auth ---
# Set this to enable token-based authentication on all /services routes.
# Leave unset (or empty) to run in open/dev mode.
# Clients must send:  Authorization: Bearer <your-token>
AUTH_TOKEN=

# --- Database ---
# Path to the SQLite database file.
# In Kubernetes, point this at a PersistentVolumeClaim mount path.
# Example: DB_PATH=/data/kubeshipper.sqlite
# Default: kubeshipper.sqlite (in the current working directory)
DB_PATH=
